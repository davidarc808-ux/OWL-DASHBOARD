<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="owl_tablero.OwlDashboard" owl="1">
        <div class="owl_dashboard">

            <div class="dashboard_header">
                <h2>Tablero de Compras y Ventas</h2>
                <span class="dashboard_subtitle">Resumen general de operaciones</span>
            </div>

            <div class="dashboard_tiles">

                <div class="tile tile_ventas">
                    <div class="tile_icon">🛒</div>
                    <div class="tile_content">
                        <span class="tile_label">Total Ventas</span>
                        <span class="tile_amount">
                            <t t-esc="formatMoney(state.total_ventas)"/>
                        </span>
                        <div class="tile_details">
                            <span>📋 <t t-esc="state.num_ventas"/> órdenes</span>
                            <span>📄 Última: <t t-esc="state.ultima_venta"/></span>
                        </div>
                    </div>
                </div>

                <div class="tile tile_compras">
                    <div class="tile_icon">📦</div>
                    <div class="tile_content">
                        <span class="tile_label">Total Compras</span>
                        <span class="tile_amount">
                            <t t-esc="formatMoney(state.total_compras)"/>
                        </span>
                        <div class="tile_details">
                            <span>📋 <t t-esc="state.num_compras"/> órdenes</span>
                            <span>📄 Última: <t t-esc="state.ultima_compra"/></span>
                        </div>
                    </div>
                </div>

                <div t-attf-class="tile tile_ganancia {{ state.estado_ganancia }}">
                    <div class="tile_icon">
                        <t t-if="state.estado_ganancia === 'positivo'">📈</t>
                        <t t-else="">📉</t>
                    </div>
                    <div class="tile_content">
                        <span class="tile_label">Ganancia Neta</span>
                        <span class="tile_amount">
                            <t t-esc="formatMoney(state.ganancia)"/>
                        </span>
                        <div class="tile_details">
                            <span t-if="state.estado_ganancia === 'positivo'">
                                ✅ Operación rentable
                            </span>
                            <span t-else="">
                                ⚠️ Compras superan ventas
                            </span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="dashboard_section">
                <div class="section_header">
                    <h3>🛒 Registros de Ventas</h3>
                    <span class="section_badge ventas_badge">
                        <t t-esc="state.num_ventas"/> órdenes
                    </span>
                </div>
                <table class="dashboard_table">
                    <thead>
                        <tr>
                            <th>Orden</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.registros_ventas" t-as="orden" t-key="orden.id">
                            <tr>
                                <td class="orden_nombre"><t t-esc="orden.nombre"/></td>
                                <td><t t-esc="orden.cliente"/></td>
                                <td><t t-esc="orden.fecha"/></td>
                                <td class="orden_total"><t t-esc="formatMoney(orden.total)"/></td>
                                <td>
                                    <span t-attf-class="estado_badge estado_{{ orden.estado }}">
                                        <t t-esc="orden.estado"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                        <t t-if="state.registros_ventas.length === 0">
                            <tr>
                                <td colspan="5" class="sin_registros">
                                    Sin registros de ventas
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <div class="dashboard_section">
                <div class="section_header">
                    <h3>📦 Registros de Compras</h3>
                    <span class="section_badge compras_badge">
                        <t t-esc="state.num_compras"/> órdenes
                    </span>
                </div>
                <table class="dashboard_table">
                    <thead>
                        <tr>
                            <th>Orden</th>
                            <th>Proveedor</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.registros_compras" t-as="orden" t-key="orden.id">
                            <tr>
                                <td class="orden_nombre"><t t-esc="orden.nombre"/></td>
                                <td><t t-esc="orden.proveedor"/></td>
                                <td><t t-esc="orden.fecha"/></td>
                                <td class="orden_total"><t t-esc="formatMoney(orden.total)"/></td>
                                <td>
                                    <span t-attf-class="estado_badge estado_{{ orden.estado }}">
                                        <t t-esc="orden.estado"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                        <t t-if="state.registros_compras.length === 0">
                            <tr>
                                <td colspan="5" class="sin_registros">
                                    Sin registros de compras
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

        </div>
    </t>
</templates>